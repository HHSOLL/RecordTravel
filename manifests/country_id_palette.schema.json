{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travelrecord.local/schemas/country_id_palette.schema.json",
  "title": "Travel Globe Country ID Palette",
  "type": "object",
  "required": ["schema_version", "version", "generated_at", "null_entry", "entries"],
  "properties": {
    "schema_version": {"type": "string"},
    "version": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "null_entry": {
      "type": "object",
      "required": ["id", "rgb", "semantic", "display_name"],
      "properties": {
        "id": {"type": "integer", "const": 0},
        "rgb": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0, "maximum": 255},
          "minItems": 3,
          "maxItems": 3
        },
        "semantic": {"type": "string"},
        "display_name": {"type": "string"},
        "iso_a2": {"type": ["string", "null"]},
        "iso_a3": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rgb", "iso_a2", "iso_a3", "display_name", "center_lat", "center_lon", "bbox"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "rgb": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0, "maximum": 255},
            "minItems": 3,
            "maxItems": 3
          },
          "iso_a2": {"type": "string"},
          "iso_a3": {"type": "string"},
          "display_name": {"type": "string"},
          "center_lat": {"type": "number", "minimum": -90, "maximum": 90},
          "center_lon": {"type": "number", "minimum": -180, "maximum": 180},
          "bbox": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 4,
            "maxItems": 4
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
