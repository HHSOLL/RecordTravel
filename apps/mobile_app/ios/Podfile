platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end

    # Some plugin podspecs can incorrectly place privacy manifests in the
    # Sources build phase, which breaks device builds before Pods_Runner links.
    next unless target.respond_to?(:source_build_phase)

    source_phase = target.source_build_phase
    next unless source_phase

    source_phase.files
      .select do |build_file|
        file_ref = build_file.file_ref
        next false unless file_ref

        file_ref.path&.end_with?('.xcprivacy')
      end
      .each do |build_file|
        source_phase.remove_build_file(build_file)
      end
  end

  frameworks_script = File.join(
    __dir__,
    'Pods',
    'Target Support Files',
    'Pods-Runner',
    'Pods-Runner-frameworks.sh'
  )

  if File.exist?(frameworks_script)
    script = File.read(frameworks_script)
    patched = <<~'SH'
      if [ -r "${BUILT_PRODUCTS_DIR}/$1" ]; then
        local source="${BUILT_PRODUCTS_DIR}/$1"
      elif [ -r "${BUILT_PRODUCTS_DIR}/$(basename "$1")" ]; then
        local source="${BUILT_PRODUCTS_DIR}/$(basename "$1")"
      elif [ -r "$1" ]; then
        local source="$1"
      elif [ -n "${PODS_CONFIGURATION_BUILD_DIR:-}" ]; then
        local pod_framework_dir="$(basename "$(dirname "$1")")"
        local pod_framework_path="${PODS_CONFIGURATION_BUILD_DIR}/${pod_framework_dir}/$(basename "$1")"
        if [ -r "${pod_framework_path}" ]; then
          local source="${pod_framework_path}"
        fi
      fi

        local destination="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"

        if [ -z "${source:-}" ]; then
          echo "warning: [CP] Unable to find framework source for $1"
          return
        fi

        if [ -L "${source}" ]; then
    SH

    script.sub!(
      /  if \[ -r "\$\{BUILT_PRODUCTS_DIR\}\/\$1" \]; then\n    local source="\$\{BUILT_PRODUCTS_DIR\}\/\$1"\n  elif \[ -r "\$\{BUILT_PRODUCTS_DIR\}\/\$\(basename "\$1"\)" \]; then\n    local source="\$\{BUILT_PRODUCTS_DIR\}\/\$\(basename "\$1"\)"\n  elif \[ -r "\$1" \]; then\n    local source="\$1"\n  fi\n\n  local destination="\$\{TARGET_BUILD_DIR\}\/\$\{FRAMEWORKS_FOLDER_PATH\}"\n\n  if \[ -L "\$\{source\}" \]; then\n/m,
      patched
    )

    File.write(frameworks_script, script)
  end
end
